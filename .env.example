# Copie este arquivo para .env.local e preencha com suas credenciais do Supabase

# URL do seu projeto Supabase (encontrado no dashboard do Supabase)
VITE_SUPABASE_URL=https://seuprojectid.supabase.co

# Chave anônima do Supabase (encontrada no dashboard do Supabase > Settings > API)
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui